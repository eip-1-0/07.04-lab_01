{
  "extends": [
    "config:recommended",
    ":configMigration",
    "docker:pinDigests"
  ],
  "enabledManagers": [
    "dockerfile",
    "github-actions"
  ],
  "dependencyDashboard": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10,
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions", "dockerfile"],
      "matchUpdateTypes": ["minor", "patch"]
    }
  ]
}
